{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "ZenTube v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": true
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "node scripts/bump-manifest.js ${version}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog\n\nAll notable changes to ZenTube are documented here.\n"
    }
  }
}
